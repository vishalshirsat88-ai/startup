from flask import Flask, jsonify, request
from flask_cors import CORS
import nltk
from nltk.sentiment import SentimentIntensityAnalyzer

app = Flask(__name__)
CORS(app)

# Initialize sentiment analyzer
sia = SentimentIntensityAnalyzer()

# Sample mood tracking data
mood_data = {
    "user1": {"mood": "happy", "date": "2024-09-16"},
    "user2": {"mood": "sad", "date": "2024-09-15"}
}

# Sample personalized recommendations
recommendations = {
    "stress": ["Exercise regularly", "Practice mindfulness"],
    "anxiety": ["Seek social support", "Challenge negative thoughts"]
}

# API endpoint for mood tracking
@app.route('/mood', methods=['POST'])
def track_mood():
    data = request.json
    user_id = data['user_id']
    mood = data['mood']
    mood_data[user_id] = {"mood": mood, "date": "2024-09-16"}
    return jsonify({"message": "Mood tracked successfully"})

# API endpoint for personalized recommendations
@app.route('/recommendations', methods=['GET'])
def get_recommendations():
    return jsonify(recommendations)

# API endpoint for sentiment analysis
@app.route('/sentiment', methods=['POST'])
def analyze_sentiment():
    data = request.json
    text = data['text']
    sentiment = sia.polarity_scores(text)
    return jsonify({"sentiment": sentiment})

if __name__ == '__main__':
    app.run(debug=True)
