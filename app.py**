recommendations = [
    {"id": 1, "title": "Use public transport", "description": "Reduce carbon footprint by using public transport"},
    {"id": 2, "title": "Use energy-efficient appliances", "description": "Reduce energy consumption by using energy-efficient appliances"}
]

# API endpoint to get user data
@app.route('/users', methods=['GET'])
def get_users():
    return jsonify(users)

# API endpoint to get sustainability recommendations
@app.route('/recommendations', methods=['GET'])
def get_recommendations():
    return jsonify(recommendations)

# API endpoint to create a new user
@app.route('/users', methods=['POST'])
def create_user():
    new_user = {
        "id": len(users) + 1,
        "name": request.json['name'],
        "email": request.json['email']
    }
    users.append(new_user)
    return jsonify(new_user), 201

if __name__ == '__main__':
    port = int(os.environ.get('PORT', 5000))
    app.run(host='0.0.0.0', port=port)
